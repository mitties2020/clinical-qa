# Render deployment flag (auto-set by Render)
RENDER=true

# DeepSeek AI API
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat

# Whisper config
WHISPER_MODEL_SIZE=tiny

# Stripe subscription
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret
STRIPE_PRICE_ID_PRO=price_1T3yFlHvfV7kt9wle2LpbpU0

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id

# Flask/Auth secrets
FLASK_SECRET_KEY=dev-secret-change-in-production
APP_SECRET_KEY=dev-secret-change-in-production

# App URLs
APP_BASE_URL=https://www.vividmedi.com

# Twilio calling
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_NUMBER=+61400000000
DOCTOR_PHONE=+61400000000
DEEPGRAM_API_KEY=your_deepgram_api_key
TWILIO_STREAM_SECRET=change_me_to_a_long_random_string

# Database
DB_PATH=vividmedi.db

# Creator account email (auto-pro)
CREATOR_EMAIL=your_creator_email@example.com
