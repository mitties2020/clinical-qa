{
  "manifest_version": 3,
  "name": "VividMedi MediRecords Sync",
  "version": "0.2.0",
  "permissions": ["activeTab", "clipboardWrite", "scripting", "storage"],
  "host_permissions": ["https://vividmedi.com/*", "https://*.medirecords.com/*", "https://*.medirecords.com.au/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false,
      "world": "MAIN"
    }
  ],
  "action": { "default_title": "VividMedi Sync", "default_popup": "popup.html" }
}
